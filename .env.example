# Agentic Governance Gateway – example environment variables
# Copy to .env and adjust values. Never commit .env.

# Logging
LOG_LEVEL=info

# Policy engine
OPA_POLICY_DIR=./policies
OPA_WASM_PATH=./policies/bundle.wasm
# If OPA wasm bundle is unavailable, the in-process JS evaluator is used.
POLICY_FALLBACK_JS=true

# Database (traceability & audit). Use sqlite for local dev.
DATABASE_URL=sqlite://./data/governance.db
# Or for Postgres: postgresql://user:pass@localhost:5432/governance

# Budget control – default per-agent limits (USD)
DEFAULT_DAILY_BUDGET_USD=50
DEFAULT_MONTHLY_BUDGET_USD=1000

# Human-in-the-loop
HITL_TIMEOUT_SECONDS=300
HITL_NOTIFICATION_PROVIDER=console

# MCP server
MCP_SERVER_NAME=agentic-governance-gateway
MCP_SERVER_VERSION=0.1.0